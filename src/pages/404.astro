---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import CardAnalisis from '../components/CardAnalisis.astro';

const ultimos = (await getCollection('analisis'))
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 3);
---

<Base
  title="Página no encontrada — Campiva Intelligence"
  description="La página que buscás no existe o cambió de dirección.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-14">
    <p class="text-[0.78rem] font-bold uppercase tracking-[0.18em] text-amber-deep">Error 404</p>
    <h1 class="font-serif text-[2.5rem] leading-tight font-semibold text-navy-950 mt-2">
      Esta página no cotiza en nuestro mercado
    </h1>
    <p class="text-slate-600 text-[1.05rem] leading-relaxed mt-3 max-w-[52ch]">
      El enlace no existe o cambió de dirección. Lo que sí tenemos: el análisis del día,
      el radar y los indicadores, siempre en la portada.
    </p>
    <a
      href="/"
      class="inline-block rounded-lg bg-navy-900 text-white text-[0.9rem] font-semibold px-6 py-3 mt-6 hover:bg-navy-800 transition-colors duration-200 cursor-pointer">
      Volver a la portada
    </a>

    {
      ultimos.length > 0 && (
        <div class="mt-14 pb-4">
          <div class="flex items-center gap-4 mb-6">
            <h2 class="text-[0.78rem] font-bold uppercase tracking-[0.18em] text-navy-950 whitespace-nowrap">
              Mientras tanto, lo último de la casa
            </h2>
            <div class="flex-1 border-t border-slate-200" />
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10">
            {ultimos.map((e) => (
              <CardAnalisis entry={e} />
            ))}
          </div>
        </div>
      )
    }
  </div>
</Base>
