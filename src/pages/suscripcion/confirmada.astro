---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Suscripción confirmada — Campiva Intelligence"
  description="Tu suscripción al boletín de Campiva Intelligence quedó confirmada."
  noindex>
  <div class="max-w-xl mx-auto px-4 sm:px-6 pt-16 pb-10 text-center min-h-[45vh]">
    <p class="text-[0.78rem] font-bold uppercase tracking-[0.18em] text-leaf-700">Listo</p>
    <h1 class="font-serif text-[2.1rem] leading-tight font-semibold text-navy-950 mt-2">
      Estás en la lista
    </h1>
    <p class="text-slate-600 text-[1.02rem] leading-relaxed mt-4">
      Bienvenido al boletín de <strong>Campiva Intelligence</strong>: la lectura de la casa
      sobre los mercados agro de Bolivia y LATAM, con cifras verificadas. Mientras tanto,
      el radar y los indicadores de hoy ya están en la portada.
    </p>
    <div class="flex flex-wrap justify-center gap-3 mt-8">
      <a
        href="/"
        class="inline-block rounded-lg bg-leaf-500 text-navy-950 text-[0.9rem] font-bold px-6 py-3 hover:bg-leaf-300 transition-colors duration-200 cursor-pointer">
        Ir a la portada
      </a>
      <a
        href="/analisis/"
        class="inline-block rounded-lg ring-1 ring-slate-300 text-navy-900 text-[0.9rem] font-semibold px-6 py-3 hover:ring-navy-600 transition-colors duration-200 cursor-pointer">
        Leer los análisis
      </a>
    </div>
  </div>
</Base>
