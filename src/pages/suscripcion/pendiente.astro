---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Revisá tu correo — Campiva Intelligence"
  description="Te enviamos un correo para confirmar tu suscripción al boletín."
  noindex>
  <div class="max-w-xl mx-auto px-4 sm:px-6 pt-16 pb-10 text-center min-h-[45vh]">
    <p class="text-[0.78rem] font-bold uppercase tracking-[0.18em] text-leaf-700">Un paso más</p>
    <h1 class="font-serif text-[2.1rem] leading-tight font-semibold text-navy-950 mt-2">
      Revisá tu correo
    </h1>
    <p class="text-slate-600 text-[1.02rem] leading-relaxed mt-4">
      Te enviamos un mensaje con un botón para <strong>confirmar tu suscripción</strong>.
      Si no aparece en unos minutos, mirá en spam o promociones — y marcanos como
      remitente seguro para no perderte ningún boletín.
    </p>
    <a
      href="/"
      class="inline-block rounded-lg bg-navy-900 text-white text-[0.9rem] font-semibold px-6 py-3 mt-8 hover:bg-navy-800 transition-colors duration-200 cursor-pointer">
      Volver a la portada
    </a>
  </div>
</Base>
