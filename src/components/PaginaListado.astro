---
import type { CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import CardAnalisis from './CardAnalisis.astro';

interface Props {
  kicker: string;
  titulo: string;
  descripcion: string;
  entries: CollectionEntry<'analisis'>[];
  rssHref?: string;
}
const { kicker, titulo, descripcion, entries, rssHref } = Astro.props;
---

<Base title={`${titulo} — Campiva Intelligence`} description={descripcion}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-10">
    <nav aria-label="Miga de pan" class="text-[0.72rem] font-bold uppercase tracking-[0.14em] text-slate-500">
      <a href="/" class="hover:text-navy-900 transition-colors duration-200 cursor-pointer">Inicio</a>
      <span class="text-slate-300 mx-1.5" aria-hidden="true">/</span>
      <span class="text-amber-deep">{kicker}</span>
    </nav>
    <div class="flex flex-wrap items-end justify-between gap-4 mt-3">
      <h1 class="font-serif text-[2.3rem] leading-tight font-semibold text-navy-950">{titulo}</h1>
      {
        rssHref && (
          <a
            href={rssHref}
            class="inline-flex items-center gap-1.5 text-[0.78rem] font-semibold text-slate-500 hover:text-navy-900 transition-colors duration-200 cursor-pointer pb-2">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0ZM1.82 8.4v3.02c5.94 0 10.76 4.82 10.76 10.76h3.02c0-7.6-6.17-13.78-13.78-13.78Zm0-6.58v3.02c9.57 0 17.34 7.77 17.34 17.34h3.02C22.18 10.87 13.13 1.82 1.82 1.82Z" />
            </svg>
            RSS
          </a>
        )
      }
    </div>
    <p class="text-slate-600 text-[1.02rem] leading-relaxed mt-3 max-w-[62ch]">{descripcion}</p>

    {
      entries.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12 mt-10">
          {entries.map((e) => (
            <CardAnalisis entry={e} />
          ))}
        </div>
      ) : (
        <p class="mt-10 rounded-xl bg-slate-50 ring-1 ring-slate-200 px-5 py-6 text-slate-600 text-[0.95rem]">
          Todavía no publicamos análisis en esta sección. El radar diario y los nuevos
          análisis aparecen cada mañana.
        </p>
      )
    }
  </div>
</Base>
