---
import Badge from './Badge.astro';
import ScoreChip from './ScoreChip.astro';
import { labelPais, labelVertical } from '../lib/format';

interface Props {
  item: {
    titular: string;
    resumen: string;
    fuente: string;
    url: string;
    vertical: string;
    pais: string;
    impacto: string;
    score: number;
  };
}
const { item } = Astro.props;

const impactoCls =
  item.impacto === 'alto'
    ? 'text-amber-deep'
    : item.impacto === 'medio'
      ? 'text-navy-500'
      : 'text-slate-400';
---

<li class="flex gap-3.5 py-4 border-b border-slate-200 last:border-b-0">
  <div class="pt-0.5">
    <ScoreChip score={item.score} />
  </div>
  <div class="min-w-0">
    <h3 class="font-serif text-[1.05rem] leading-snug font-semibold text-navy-900">
      <a
        href={item.url}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:underline decoration-amber-brand decoration-2 underline-offset-2 cursor-pointer">
        {item.titular}
        <svg
          class="inline-block h-3 w-3 mb-0.5 ml-0.5 text-slate-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M9 7h8v8"></path>
        </svg>
      </a>
    </h3>
    <p class="text-[0.86rem] text-slate-600 leading-relaxed mt-1">{item.resumen}</p>
    <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1.5 mt-2 text-[0.7rem]">
      <span class="font-semibold text-slate-500 uppercase tracking-wide">{item.fuente}</span>
      <span class:list={['font-bold uppercase tracking-wide', impactoCls]}>
        ● impacto {item.impacto}
      </span>
      <Badge kind="vertical" label={labelVertical(item.vertical)} href={`/vertical/${item.vertical}/`} />
      <Badge kind="pais" label={labelPais(item.pais)} href={`/pais/${item.pais.toLowerCase()}/`} />
    </div>
  </div>
</li>
