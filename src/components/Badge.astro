---
/** Badge de taxonomía: vertical, país, tipo o impacto. Con href se vuelve link a la taxonomía. */
interface Props {
  kind: 'vertical' | 'pais' | 'tipo' | 'impacto';
  label: string;
  dark?: boolean;
  href?: string;
}
const { kind, label, dark = false, href } = Astro.props;
const Tag = href ? 'a' : 'span';

const styles: Record<string, string> = {
  vertical: dark
    ? 'bg-leaf-300/10 text-leaf-300 ring-leaf-300/30'
    : 'bg-leaf-500/10 text-leaf-700 ring-leaf-500/40',
  pais: dark
    ? 'bg-amber-brand/10 text-amber-soft ring-amber-brand/30'
    : 'bg-amber-brand/10 text-amber-deep ring-amber-deep/25',
  tipo: dark
    ? 'bg-white/5 text-slate-300 ring-white/15'
    : 'bg-navy-50 text-navy-600 ring-navy-200',
  impacto: dark
    ? 'bg-white/5 text-slate-300 ring-white/15'
    : 'bg-slate-100 text-slate-600 ring-slate-200',
};
---

<Tag
  href={href}
  class:list={[
    'inline-flex items-center rounded-full px-2.5 py-0.5 text-[0.68rem] font-semibold uppercase tracking-[0.08em] ring-1 ring-inset whitespace-nowrap',
    styles[kind],
    href && 'cursor-pointer hover:ring-2 transition-shadow duration-200',
  ]}>{label}</Tag>
